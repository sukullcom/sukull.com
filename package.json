{
  "name": "sukull",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "payment-server": "cd payment-server && node server.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run payment-server\"",
    "build": "npm run lint:fix && next build",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:studio": "npx drizzle-kit studio --host 127.0.0.1 --port 4983",
    "db:push": "npx drizzle-kit push",
    "db:generate": "npx drizzle-kit generate",
    "db:apply": "tsx scripts/apply-migration.ts",
    "db:analyze": "tsx scripts/analyze-tables.ts",
    "db:explain": "tsx scripts/explain-hot-queries.ts",
    "schools:import": "node ./scripts/import-schools.js",
    "schools:upload": "tsx ./scripts/upload-schools.ts"
  },
